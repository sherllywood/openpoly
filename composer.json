{
  "name": "openpoly/openpoly",
  "description": "GPL multilingual WordPress plugin — WPML functional clone.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "keywords": ["wordpress", "multilingual", "translation", "i18n", "wpml"],
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.9",
    "wp-coding-standards/wpcs": "^3.1",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "phpstan/phpstan": "^1.11",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "phpunit/phpunit": "^9.6",
    "brain/monkey": "^2.6"
  },
  "autoload": {
    "psr-4": {
      "OpenPoly\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OpenPoly\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "phpcs",
    "lint:fix": "phpcbf",
    "stan": "phpstan analyse --memory-limit=1G",
    "test:unit": "phpunit --testsuite=unit",
    "test:integration": "phpunit --testsuite=integration",
    "test:all": "phpunit",
    "compat": "phpcs -p --standard=PHPCompatibilityWP --runtime-set testVersion 7.4-8.3 src/"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
