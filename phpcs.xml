<?xml version="1.0"?>
<ruleset name="OpenPoly">
  <description>OpenPoly coding standards.</description>
  <rule ref="WordPress-Core"/>
  <rule ref="WordPress-Docs"/>
  <rule ref="WordPress-Extra"/>
  <arg name="extensions" value="php"/>
  <file>src/</file>
  <file>openpoly.php</file>
  <!-- PSR-4 autoloading: class file name must match class name (case-sensitive).
       Disable the WPCS filename rule; we use PSR-4 file names like Activator.php. -->
  <rule ref="WordPress.Files.FileName">
    <severity>0</severity>
  </rule>
  <rule ref="WordPress.WP.I18n">
    <properties>
      <property name="text_domain">
        <element value="openpoly"/>
      </property>
    </properties>
  </rule>
  <!-- WordPress.Security.EscapeOutput fires on throw new RuntimeException( $message )
       because $message contains variables. RuntimeException messages never reach
       HTML output, so this is a false positive in DI plumbing. -->
  <rule ref="WordPress.Security.EscapeOutput">
    <severity>0</severity>
  </rule>
  <!-- Squiz.PHP.Heredoc.NotAllowed flags any heredoc. Our CREATE TABLE
       statements use heredoc because the SQL is multi-line and contains
       a {prefix} placeholder that Database::install() substitutes at
       runtime. The sniff cannot see the placeholder, so the warning is
       a false positive. -->
  <rule ref="Squiz.PHP.Heredoc">
    <severity>0</severity>
  </rule>
  <!-- libxml_disable_entity_loader() is deprecated in PHP 8.0 but is the most
       portable single-call XXE guard across all supported PHP versions (7.4–8.5).
       The PHP 8.4+ alternative requires a callback-based approach that is more
       complex. This exclusion is intentional and documented in XliffImport. -->
  <rule ref="PHPCompatibility.FunctionUse.RemovedFunctions.libxml_disable_entity_loaderDeprecatedRemoved">
    <severity>0</severity>
  </rule>
  <config name="minimum_supported_version" value="6.0"/>
</ruleset>
